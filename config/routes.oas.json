{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "cyeam-open",
    "description": "cyeam.com 开放接口网关。提供旅游线路图生成、二维码生成等服务。"
  },
  "paths": {
    "/api/roadbook/csv": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "生成旅游线路图",
        "description": "",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://www.cyeam.com"
            }
          },
          "policies": {
            "inbound": [
              "api-key-inbound-1",
              "set-headers-inbound"
            ]
          }
        },
        "operationId": "new-route-e309f715",
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": {
                "type": "string",
                "description": "CSV格式的地点列表，每行一个地点：名称,地址,类型,日期备注"
              },
              "example": "淄博酒店,淄博市张店区某路,住宿,4.30,入住\n八大局便民市场,淄博市张店区共青团东路,餐饮,5.1 早市逛吃"
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "分享ID"
                    },
                    "url": {
                      "type": "string",
                      "description": "路书页面链接"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/qrcode": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "生成二维码",
        "description": "",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://www.cyeam.com"
            }
          },
          "policies": {
            "inbound": [
              "api-key-inbound"
            ]
          }
        },
        "operationId": "new-route-02f05b40",
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": true,
            "description": "要编码为二维码的文本内容",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "qrcode": {
                      "type": "string",
                      "description": "Base64 编码的 PNG 二维码图片"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/slogan": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "获取每日 Slogan",
        "description": "返回一段每日激励文案，无需鉴权。",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://www.cyeam.com"
            }
          },
          "policies": {
            "inbound": []
          }
        },
        "operationId": "slogan-get",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "slogan": {
                      "type": "string",
                      "description": "每日 Slogan 文案"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
